#! /usr/bin/env bash
set -uo pipefail

#
# START A VSCODE DOCKER SANDBOX
# ./sbxvscode [-d] [project_directory]
# -d = flag to run detached / in background
# project_directory = path to directory that will be mounted into the sandbox
#
# Examples
# ./sbxvscode                       start the sandbox and the VSCode tunnel in the current directory
# ./sbxvscode /path/to/files        start the sandbox and the VSCode tunnel in the specified directory
# ./sbxvscode -d                    start the sandbox in the current directory
# ./sbxvscode -d /path/to/files     start the sandbox in the specified directory
#

usage() {
	cat <<'EOF'
Usage: sbxvscode [-d] [-h] [project_directory]
  -d                 create the sandbox without starting the VSCode tunnel
  -h                 show this help and exit
  project_directory  directory to mount into the sandbox (default: current directory)
EOF
}

# Set the sbx subcommand to use (default to run, unless -d)
CMD="run"
while getopts "dh" opt; do
	case $opt in
	d)
		CMD="create"
		;;
	h)
		usage
		exit 0
		;;
	*)
		usage
		exit 1
		;;
	esac
done
shift $((OPTIND - 1))

# path to kit directory (parent dir of this script)
KIT_DIR="$(dirname "$(readlink -f "$0")")"

# path to project workspace
# default to current working directory, if not explicitly set
WS_DIR=${1:-$(pwd)}

# Set sandbox name (basename with lowercase with special chars replaced)
NAME=$(basename "$WS_DIR")
NAME="${NAME,,}"
NAME="${NAME//[^[:alnum:]]/-}"
NAME="claude-$NAME"

# Get existing sandboxes
running=$(sbx ls -q)

#
# EXISTING SANDBOX
#
if printf '%s\n' "$running" | grep -Fxq "$NAME"; then

	# already created, ignore
	if [[ $CMD == "create" ]]; then
		echo "The sandbox $NAME already exists ..."

	# restart in existing sandbox
	else
		sbx run --name "$NAME" --kit "$KIT_DIR"
		exit 0
	fi

#
# NEW SANDBOX
#
else

	# Create a new sandbox (using create or run command)
	echo "--> Starting sandbox in workspace $WS_DIR..."
	echo "    name: $NAME"
	echo "    kit: $KIT_DIR"
	echo "    command: $CMD"

	sbx $CMD --name "$NAME" claude-vscode --kit "$KIT_DIR" "$WS_DIR"

fi
